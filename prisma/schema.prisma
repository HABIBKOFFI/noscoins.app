generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String    @id @default(uuid())
  type               UserType
  email              String?   @unique
  phone              String?
  country_code       String?
  password_hash      String?
  account_status     AccountStatus @default(active)
  suspended_until    DateTime?
  suspension_reason  String?
  subscription_tier  SubscriptionTier @default(free)
  subscription_expires_at DateTime?
  stripe_account_id  String?   // Compte Stripe Connect du propriétaire
  created_at         DateTime  @default(now())

  venues             Venue[]
  bookings           Booking[]
  sessions           UserSession[]
  wallet             Wallet?
  documents          Document[]
  favorites          Favorite[]
  notifications      Notification[]
  sent_messages      Message[]     @relation("SentMessages")
  received_messages  Message[]     @relation("ReceivedMessages")
  reviews            Review[]
  quotes             Quote[]       @relation("ClientQuotes")
  events             Event[]
  audit_logs         AuditLog[]    @relation("ActorLogs")
  kyc_reviewed       Document[]    @relation("ReviewedDocuments")
  config_updates     Config[]

  locked_availabilities Availability[] @relation("LockedByUser")

  @@map("User")
}

model Venue {
  id                       String        @id @default(uuid())
  owner_id                 String
  name                     String
  city                     String?
  address                  String?
  latitude                 Float?
  longitude                Float?
  capacity_seat            Int?
  capacity_stand           Int?
  base_price               Decimal?      @db.Decimal(12, 2)
  currency                 Currency?
  status                   VenueStatus   @default(pending)
  booking_mode             BookingMode   @default(instant)
  balance_due_days_before  Int           @default(30)
  is_off_market            Boolean       @default(false)
  secret_link              String?       @unique
  commission_override      Decimal?      @db.Decimal(5, 4)
  commission_override_until DateTime?
  created_at               DateTime      @default(now())

  owner                    User          @relation(fields: [owner_id], references: [id])
  availabilities           Availability[]
  bookings                 Booking[]
  services                 Service[]
  reviews                  Review[]
  quotes                   Quote[]
  favorites                Favorite[]
  events                   Event[]

  @@map("Venue")
}

model Availability {
  id                  String    @id @default(uuid())
  venue_id            String
  date                DateTime  @db.Date
  start_time          String
  end_time            String
  blocked             Boolean   @default(false)
  locked_until        DateTime?
  locked_by_user_id   String?
  locked_booking_id   String?
  created_at          DateTime  @default(now())

  venue               Venue     @relation(fields: [venue_id], references: [id])
  locked_by_user      User?     @relation("LockedByUser", fields: [locked_by_user_id], references: [id])
  locked_booking      Booking?  @relation("LockedBooking", fields: [locked_booking_id], references: [id])

  @@index([venue_id, date])
  @@map("Availability")
}

model Booking {
  id                    String        @id @default(uuid())
  venue_id              String
  user_id               String
  quote_id              String?
  status                BookingStatus
  total_price           Decimal       @db.Decimal(12, 2)
  deposit_amount        Decimal?      @db.Decimal(12, 2)
  service_fee_amount    Decimal?      @db.Decimal(12, 2)
  service_fee_currency  String?
  client_currency       String?
  owner_currency        String?
  expires_at            DateTime?
  created_at            DateTime      @default(now())

  venue                 Venue         @relation(fields: [venue_id], references: [id])
  user                  User          @relation(fields: [user_id], references: [id])
  quote                 Quote?        @relation(fields: [quote_id], references: [id])
  payments              Payment[]
  messages              Message[]
  reviews               Review[]
  booking_services      BookingService[]
  events                Event[]
  locked_availabilities Availability[] @relation("LockedBooking")

  @@index([status])
  @@index([user_id])
  @@map("Booking")
}

model Payment {
  id                  String        @id @default(uuid())
  booking_id          String
  amount              Decimal       @db.Decimal(12, 2)
  currency            String
  exchange_rate       Decimal?      @db.Decimal(10, 6)
  amount_converted    Decimal?      @db.Decimal(12, 2)
  commission_amount   Decimal?      @db.Decimal(12, 2)
  commission_currency String?
  method              PaymentMethod
  status              PaymentStatus
  psp_reference       String?       @unique
  refund_amount       Decimal?      @db.Decimal(12, 2)
  refund_reason       String?
  refunded_at         DateTime?
  created_at          DateTime      @default(now())

  booking             Booking       @relation(fields: [booking_id], references: [id])

  @@map("Payment")
}

model Wallet {
  id         String    @id @default(uuid())
  user_id    String    @unique
  balance    Decimal   @db.Decimal(12, 2)
  currency   String
  created_at DateTime  @default(now())

  user       User      @relation(fields: [user_id], references: [id])
  payouts    Payout[]

  @@map("Wallet")
}

model Payout {
  id          String    @id @default(uuid())
  wallet_id   String
  amount      Decimal   @db.Decimal(12, 2)
  currency    String
  status      String
  payout_date DateTime?
  created_at  DateTime  @default(now())

  wallet      Wallet    @relation(fields: [wallet_id], references: [id])

  @@map("Payout")
}

model Service {
  id          String          @id @default(uuid())
  venue_id    String
  name        String
  price       Decimal         @db.Decimal(12, 2)
  currency    String
  type        ServiceType?
  category    String?
  description String?
  created_at  DateTime        @default(now())

  venue           Venue       @relation(fields: [venue_id], references: [id])
  booking_services BookingService[]

  @@map("Service")
}

model BookingService {
  id          String    @id @default(uuid())
  booking_id  String
  service_id  String
  quantity    Int
  unit_price  Decimal   @db.Decimal(12, 2)
  total_price Decimal   @db.Decimal(12, 2)
  created_at  DateTime  @default(now())

  booking     Booking   @relation(fields: [booking_id], references: [id])
  service     Service   @relation(fields: [service_id], references: [id])

  @@map("BookingService")
}

model Event {
  id          String    @id @default(uuid())
  user_id     String?
  venue_id    String?
  booking_id  String?
  event_type  String
  properties  Json?
  created_at  DateTime  @default(now())

  user        User?     @relation(fields: [user_id], references: [id])
  venue       Venue?    @relation(fields: [venue_id], references: [id])
  booking     Booking?  @relation(fields: [booking_id], references: [id])

  @@index([event_type, created_at])
  @@index([venue_id, created_at])
  @@map("Event")
}

model Message {
  id               String    @id @default(uuid())
  booking_id       String
  sender_id        String
  receiver_id      String
  content          String?
  attachment_url   String?
  attachment_type  String?
  read_at          DateTime?
  created_at       DateTime  @default(now())

  booking          Booking   @relation(fields: [booking_id], references: [id])
  sender           User      @relation("SentMessages", fields: [sender_id], references: [id])
  receiver         User      @relation("ReceivedMessages", fields: [receiver_id], references: [id])

  @@map("Message")
}

model Review {
  id                  String    @id @default(uuid())
  booking_id          String    @unique
  venue_id            String
  user_id             String
  score_cleanliness   Int?
  score_welcome       Int?
  score_value         Int?
  score_overall       Int?
  comment             String?
  created_at          DateTime  @default(now())

  booking             Booking   @relation(fields: [booking_id], references: [id])
  venue               Venue     @relation(fields: [venue_id], references: [id])
  user                User      @relation(fields: [user_id], references: [id])

  @@map("Review")
}

model Document {
  id          String          @id @default(uuid())
  user_id     String
  type        DocumentType
  file_url    String
  status      DocumentStatus  @default(pending)
  reviewed_by String?
  reviewed_at DateTime?
  created_at  DateTime        @default(now())

  user        User            @relation(fields: [user_id], references: [id])
  reviewer    User?           @relation("ReviewedDocuments", fields: [reviewed_by], references: [id])

  @@map("Document")
}

model Quote {
  id                  String      @id @default(uuid())
  venue_id            String
  client_id           String
  status              QuoteStatus @default(pending)
  requested_date      DateTime?   @db.Date
  requested_services  Json?
  proposed_price      Decimal?    @db.Decimal(12, 2)
  proposed_date       DateTime?   @db.Date
  proposed_services   Json?
  suggested_venues    Json?
  message             String?
  expires_at          DateTime?
  created_at          DateTime    @default(now())

  venue               Venue       @relation(fields: [venue_id], references: [id])
  client              User        @relation("ClientQuotes", fields: [client_id], references: [id])
  bookings            Booking[]

  @@map("Quote")
}

model Favorite {
  id         String    @id @default(uuid())
  user_id    String
  venue_id   String
  created_at DateTime  @default(now())

  user       User      @relation(fields: [user_id], references: [id])
  venue      Venue     @relation(fields: [venue_id], references: [id])

  @@unique([user_id, venue_id])
  @@map("Favorite")
}

model Notification {
  id         String    @id @default(uuid())
  user_id    String
  type       String
  title      String
  body       String?
  read_at    DateTime?
  created_at DateTime  @default(now())

  user       User      @relation(fields: [user_id], references: [id])

  @@map("Notification")
}

model UserSession {
  id            String    @id @default(uuid())
  user_id       String
  refresh_token String    @unique
  expires_at    DateTime
  created_at    DateTime  @default(now())

  user          User      @relation(fields: [user_id], references: [id])

  @@map("UserSession")
}

model Config {
  key         String    @id
  value       String
  description String?
  updated_by  String?
  updated_at  DateTime  @default(now())

  updater     User?     @relation(fields: [updated_by], references: [id])

  @@map("Config")
}

model AuditLog {
  id          String    @id @default(uuid())
  actor_id    String?
  action      String
  target_type String?
  target_id   String?
  metadata    Json?
  ip_address  String?
  created_at  DateTime  @default(now())

  actor       User?     @relation("ActorLogs", fields: [actor_id], references: [id])

  @@map("AuditLog")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserType {
  client
  owner
  admin
}

enum AccountStatus {
  active
  suspended
  blacklisted
}

enum SubscriptionTier {
  free
  premium
}

enum VenueStatus {
  pending
  validated
  published
  suspended
}

enum BookingMode {
  instant
  request
}

enum Currency {
  EUR
  XOF
}

enum BookingStatus {
  draft
  locked
  confirmed
  paid
  cancelled
  completed
}

enum PaymentMethod {
  card
  apple_pay
  google_pay
  sepa
  orange_money
  mtn
  moov
  wave
}

enum PaymentStatus {
  pending
  succeeded
  failed
  refunded
}

enum ServiceType {
  mandatory
  optional
}

enum DocumentType {
  identity
  rib
  business_registration
  other
}

enum DocumentStatus {
  pending
  approved
  rejected
}

enum QuoteStatus {
  pending
  countered
  accepted
  refused
  expired
}
